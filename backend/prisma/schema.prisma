generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

/// *
/// * ================= OTP =================
model emailotp {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

/// *
/// * ================= EVENT =================
model event {
  id                    Int          @id @default(autoincrement())
  eventId               String       @unique
  name                  String
  startDate             DateTime
  endDate               DateTime
  isInternal            Boolean      @default(true)
  allocatedHours        Float        @default(0)
  qrSecretKey           String?
  status                event_status @default(ACTIVE)
  maxParticipants       Int          @default(0) // Ceiling for roster
  isRosterSubmitted     Boolean      @default(false) // True when Student Coordinator submits draft
  isRosterApproved      Boolean      @default(false) // True when Staff locks the roster
  staffCoordinatorId    Int?         // The Faculty member in charge
  studentCoordinatorId  Int?         // The Delegate Student
  timeline              Json?        // Audit trail for administrative changes
  ods                   od[]

  staffCoordinator      faculty?     @relation("StaffCoordinator", fields: [staffCoordinatorId], references: [id])
  studentCoordinator    student?     @relation("StudentCoordinator", fields: [studentCoordinatorId], references: [id])

  @@index([staffCoordinatorId])
  @@index([studentCoordinatorId])
}

/// *
/// * ================= COMPANY =================
model company {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  location   String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  offers     offer[]
}

/// *
/// * ================= OFFER =================
model offer {
  id          Int      @id @default(autoincrement())
  studentId   Int
  companyId   Int
  lpa         String?
  offerLetter String?
  placedDate  DateTime
  createdAt   DateTime @default(now())
  ods         od[]
  company     company  @relation(fields: [companyId], references: [id])
  student     student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([companyId])
}

/// *
/// * ================= OD =================
model od {
  id                  Int       @id @default(autoincrement())
  trackerId           String    @unique
  type                od_type
  startDate           DateTime
  endDate             DateTime
  duration            Int
  proofFile           String?
  studentId           Int
  eventId             Int?
  status              od_status @default(PENDING)
  createdAt           DateTime  @default(now())
  offerFile           String?
  activityId          String?   @unique
  remarks             String?   @db.Text
  timeline            Json?
  verificationDetails Json?
  offerId             Int?
  erpSyncStatus       ErpSyncStatus @default(PENDING)
  event               event?    @relation(fields: [eventId], references: [id])
  offer               offer?            @relation(fields: [offerId], references: [id])
  student             student           @relation(fields: [studentId], references: [id])
  report              InternshipReport?

  @@index([studentId])
  @@index([eventId])
  @@index([offerId])
}

model student {
  id               Int      @id @default(autoincrement())
  rollNo           String   @unique
  name             String
  email            String   @unique
  department       String
  semester         Int
  parentPhone      String?
  createdAt                 DateTime @default(now())
  mentorId                  Int?
  placement_status          String?
  internalHoursUsed         Float    @default(0)
  ods              od[]
  offers           offer[]
  reports          InternshipReport[]
  coordinatedEvents event[]  @relation("StudentCoordinator")
  mentor           faculty? @relation("StudentMentor", fields: [mentorId], references: [id])

  @@index([mentorId])
}

model faculty {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  department String?
  createdAt  DateTime  @default(now())
  facultyId  String    @unique
  students   student[] @relation("StudentMentor")
  coordinatedEvents event[] @relation("StaffCoordinator")
}

model admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model notification {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(255)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  type      String   @default("INFO") @db.VarChar(50)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

/// *
/// * ================= ACTIVE SESSION (Single-login) =================
model activesession {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  sessionId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, role])
  @@index([sessionId])
}

enum od_type {
  INTERNAL
  INTERNSHIP
}

enum event_status {
  ACTIVE
  INACTIVE
}

enum od_status {
  PROVISIONAL
  PENDING
  DOCS_VERIFIED
  MENTOR_APPROVED
  APPROVED
  REJECTED
}

/// *
/// * ================= CALENDAR EVENT =================
model CalendarEvent {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  type        EventType @default(EVENT)
  createdAt   DateTime @default(now())
}

enum EventType {
  EXAM
  HOLIDAY
  EVENT
}

/// *
/// * ================= INTERNSHIP REPORT =================
model InternshipReport {
  id        Int          @id @default(autoincrement())
  studentId Int
  odId      Int          @unique // ✅ Link to specific OD
  fileUrl   String
  status    ReportStatus @default(PENDING)
  remarks   String?      @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  student   student      @relation(fields: [studentId], references: [id])
  od        od           @relation(fields: [odId], references: [id])

  @@index([studentId])
  @@index([odId])
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

/// *
/// * ================= ERP SYNC =================
enum ErpSyncStatus {
  PENDING
  SYNCED
  FAILED
}

/// *
/// * ================= LOGIN HISTORY =================
model loginhistory {
  id         Int      @id @default(autoincrement())
  email      String
  role       String
  ip         String?
  userAgent  String?
  deviceName String?
  browser    String?
  os         String?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
